[Desktop Entry]
Name=qBit Remote
Comment=Pause or throttle qBittorrent downloads when specific programs are running
Type=Application
Icon=io.github.BlakeGardner.cosmic-ext-applet-qbit-remote
Exec=cosmic-ext-applet-qbit-remote %F
Terminal=false
StartupNotify=true
Categories=Utility;Network;
Keywords=torrent;qbittorrent;bandwidth;cosmic;
