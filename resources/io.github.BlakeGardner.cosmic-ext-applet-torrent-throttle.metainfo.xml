<component type="desktop-application">
  <id>io.github.BlakeGardner.cosmic-ext-applet-torrent-throttle</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Torrent Throttle for the COSMIC™ Desktop</name>
  <summary>Pause or throttle torrent downloads when specific programs are running</summary>
  <description>
    <p>
      Monitors running processes on your system and automatically pauses or throttles
      torrent downloads when a matching program is detected. Downloads resume or
      speed limits are restored when the program exits.
    </p>
    <p>Features:</p>
    <ul>
      <li>Pause all torrents or apply speed throttle when matching processes are running</li>
      <li>Configurable process name patterns (substring match)</li>
      <li>Automatic resume/restore when matching processes exit</li>
      <li>Connects to qBittorrent via its Web API (more clients planned)</li>
      <li>Panel applet for the COSMIC™ desktop</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/BlakeGardner/cosmic-ext-applet-torrent-throttle</url>
  <url type="bugtracker">https://github.com/BlakeGardner/cosmic-ext-applet-torrent-throttle/issues</url>
