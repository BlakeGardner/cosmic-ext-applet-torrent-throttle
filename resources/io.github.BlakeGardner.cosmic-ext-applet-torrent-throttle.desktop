[Desktop Entry]
Name=Torrent Throttle
Comment=Pause or throttle torrent downloads when specific programs are running
Type=Application
Icon=io.github.BlakeGardner.cosmic-ext-applet-torrent-throttle
Exec=cosmic-ext-applet-torrent-throttle %F
Terminal=false
StartupNotify=true
Categories=Utility;Network;
Keywords=torrent;qbittorrent;bandwidth;cosmic;
